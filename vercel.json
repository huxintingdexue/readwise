{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/articles/([^/]+)/?",
      "dest": "/api/articles.js?id=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    { "handle": "filesystem" },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
